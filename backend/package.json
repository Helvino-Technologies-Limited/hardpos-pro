{
  "name": "hardpos-pro-backend",
  "version": "1.0.0",
  "description": "HARD-POS PRO Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node_modules/.bin/ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "build": "node_modules/.bin/tsc",
    "start": "node dist/server.js",
    "db:migrate": "node_modules/.bin/ts-node -r tsconfig-paths/register src/db/migrate.ts",
    "db:seed": "node_modules/.bin/ts-node -r tsconfig-paths/register src/db/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^11.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
